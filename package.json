{
  "name": "@gs377209/storybook-testing",
  "repository": {
    "url": "git+https://github.com/gs377209/storybook-testing.git"
  },
  "private": false,
  "version": "3.0.4",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/main.js",
  "module": "./dist/main.js",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "types": "dist/main.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-storybook:docs": "storybook build --docs",
    "prepublishOnly": "npm run build",
    "chromatic": "chromatic",
    "test-storybook": "test-storybook",
    "test-storybook:coverage": "test-storybook --coverage",
    "test": "playwright install && vitest",
    "test:coverage": "playwright install && vitest --coverage",
    "test-storybook-vite": "playwright install && vitest --project=storybook",
    "test-storybook-vite:coverage": "playwright install && vitest --project=storybook --coverage"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^9.21.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/test-runner": "^0.24.3",
    "@types/node": "^22.15.14",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "@vitest/browser": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.8",
    "axe-playwright": "^2.1.0",
    "chromatic": "^16.4.0",
    "eslint": "^9.26.0",
    "eslint-plugin-react-dom": "^1.49.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-react-x": "^1.49.0",
    "eslint-plugin-storybook": "^10.3.5",
    "glob": "^11.0.2",
    "globals": "^16.1.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.3.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^3.0.8"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
